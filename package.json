{
  "name": "micah-blog-astro",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "npm run content:check && astro build && npm run search:index",
    "check": "npm run content:check && astro check",
    "preview": "astro preview",
    "new:article": "node scripts/new-article.mjs",
    "books:covers": "node scripts/fetch-book-covers.mjs",
    "books:covers:force": "node scripts/fetch-book-covers.mjs --force",
    "content:check": "node scripts/validate-articles.mjs",
    "content:fix": "node scripts/validate-articles.mjs --fix",
    "steam:snapshot": "node scripts/sync-steam-snapshot.mjs",
    "images:optimize": "node scripts/optimize-images.mjs",
    "search:index": "pagefind --site dist --output-path dist --root-selector \"[data-pagefind-body]\""
  },
  "dependencies": {
    "@astrojs/netlify": "^6.5.0",
    "astro": "^5.6.1",
    "marked": "^17.0.6",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "pagefind": "^1.4.0",
    "typescript": "^5.9.3"
  }
}

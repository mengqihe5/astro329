---
import { loadArticles } from "../lib/blog.js";

type ArticleRow = ReturnType<typeof loadArticles>[number];

interface Props {
  selectedDayLabel: string;
  calendarArticles: ArticleRow[];
}

const { selectedDayLabel, calendarArticles } = Astro.props as Props;
---
<h4>{selectedDayLabel}</h4>
<div class="day-article-grid">
  {
    calendarArticles.length > 0 ? (
      calendarArticles.map((article) => (
        <a href={`/articles/${article.slug}/`} class="card card-link day-article-card">
          <div class="day-article-thumb">
            <img
              src={article.cover}
              alt={`${article.title} 封面`}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
            />
          </div>
          <div class="day-article-content">
            <h3>{article.title}</h3>
          </div>
        </a>
      ))
    ) : (
      <p class="meta">该日期暂无文章。</p>
    )
  }
</div>

---
import { ViewTransitions } from "astro:transitions";
import { SITE_PROFILE, getNavItems } from "../lib/blog.js";

const {
  title = "Micah Hale | 션쩌꺽와",
  description = "Micah Hale 돨畇鱗、踏狗宅敦뗍션쩌。",
  currentPath = "/",
  ogImage = "/app01/avatar.jpg",
  ogType = "website",
  noindex = false,
} = Astro.props;

const navItems = getNavItems(currentPath);
const baseUrl =
  Astro.site ||
  (import.meta.env.PUBLIC_SITE_URL ? new URL(import.meta.env.PUBLIC_SITE_URL) : null) ||
  new URL(Astro.url.origin);
const canonicalUrl = new URL(`${Astro.url.pathname}${Astro.url.search}`, baseUrl).toString();
const resolvedOgImage = ogImage ? new URL(String(ogImage), baseUrl).toString() : "";
---
<!DOCTYPE html>
<html lang="zh-Hans">
  <head>
    <ViewTransitions />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
    <meta name="theme-color" content="#0d1735" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content={`${SITE_PROFILE.nickname} 돨꺽와`} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
    <meta name="twitter:card" content={resolvedOgImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
    <link rel="stylesheet" href="/app01/style.css" />
  </head>
  <body data-theme="light">
    <svg width="0" height="0" style="position:absolute">
      <symbol id="icon-home" viewBox="0 0 24 24">
        <path d="M12 3.5 3 11v9a1 1 0 0 0 1 1h5v-6h6v6h5a1 1 0 0 0 1-1v-9l-9-7.5Z" />
      </symbol>
      <symbol id="icon-gamepad" viewBox="0 0 24 24">
        <path d="M7.5 8h9a5 5 0 0 1 4.9 5.8l-.9 4.8a2.2 2.2 0 0 1-3.8 1.1l-2.2-2.4h-5l-2.2 2.4a2.2 2.2 0 0 1-3.8-1.1l-.9-4.8A5 5 0 0 1 7.5 8Zm.5 2.8H6.4v1.8H4.6v1.8h1.8v1.8h1.8v-1.8H10v-1.8H8.2v-1.8Zm8 1.4a1.3 1.3 0 1 0 0 2.6 1.3 1.3 0 0 0 0-2.6Zm2.8-1.4a1.3 1.3 0 1 0 0 2.6 1.3 1.3 0 0 0 0-2.6Z" />
      </symbol>
      <symbol id="icon-book" viewBox="0 0 24 24">
        <path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H20v17.5H7.5A2.5 2.5 0 1 0 10 22H4V4.5h1Zm2.5-.5a.5.5 0 0 0 0 1H18V4H7.5Z" />
      </symbol>
      <symbol id="icon-article" viewBox="0 0 24 24">
        <path d="M5 3h14a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Zm2 4v2h10V7H7Zm0 4v2h10v-2H7Zm0 4v2h7v-2H7Z" />
      </symbol>
      <symbol id="icon-sun" viewBox="0 0 24 24">
        <path d="M12 6.5a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11Zm0-4v2.2m0 14.6v2.2M4.8 4.8l1.6 1.6m11.2 11.2 1.6 1.6m0-14.4-1.6 1.6M6.4 17.6l-1.6 1.6M2.5 12h2.2m14.6 0h2.2" />
      </symbol>
      <symbol id="icon-moon" viewBox="0 0 24 24">
        <path d="M14.6 3.2a8.9 8.9 0 1 0 6.2 13.5 8.3 8.3 0 0 1-4.7 1.4A8.6 8.6 0 0 1 7.5 9a8.3 8.3 0 0 1 1.4-4.7 8.9 8.9 0 0 0 5.7-1.1Z" />
      </symbol>
    </svg>

    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-main">
          <div class="profile">
            <img class="avatar avatar-image" src="/app01/avatar.jpg" alt="Micah Hale avatar" />
            <h1 class="nickname">{SITE_PROFILE.nickname}</h1>
          </div>
          <nav class="nav">
            {
              navItems.map((item) => (
                <a href={item.href} class:list={["nav-link", item.active && "active"]}>
                  <svg class="icon">
                    <use href={`#icon-${item.icon}`}></use>
                  </svg>
                  <span class="nav-text">{item.title}</span>
                </a>
              ))
            }
          </nav>
        </div>
        <div class="sidebar-bottom">
          <button id="themeToggle" class="icon-button" type="button" aria-label="학뻣棍밖">
            <svg class="icon icon-sun">
              <use href="#icon-sun"></use>
            </svg>
            <svg class="icon icon-moon">
              <use href="#icon-moon"></use>
            </svg>
          </button>
        </div>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>

    <script is:inline type="module" src="/app01/app.js"></script>
  </body>
</html>

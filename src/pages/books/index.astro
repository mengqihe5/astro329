---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadBooks, groupByMonth } from "../../lib/blog.js";
import BookCard from "../../components/BookCard.astro";

const params = Astro.url.searchParams;
const modeRaw = params.get("mode") || "all";
const mode = ["all", "timeline", "tag"].includes(modeRaw) ? modeRaw : "all";
const order = params.get("order") === "asc" ? "asc" : "desc";

const books = loadBooks(order);
const allTags = [...new Set(books.flatMap((book) => book.tags || []))].sort((a, b) => a.localeCompare(b));
const selectedTagRaw = params.get("tag") || "all";
const selectedTag = selectedTagRaw !== "all" && allTags.includes(selectedTagRaw) ? selectedTagRaw : "all";

const bookTimeline = groupByMonth(books, "monthRaw");

let tagGroups = [];
if (mode === "tag") {
  if (allTags.length === 0) {
    tagGroups = [{ tag: "未分类", items: books }];
  } else if (selectedTag === "all") {
    tagGroups = allTags.map((tag) => ({ tag, items: books.filter((book) => (book.tags || []).includes(tag)) }));
  } else {
    tagGroups = [{ tag: selectedTag, items: books.filter((book) => (book.tags || []).includes(selectedTag)) }];
  }
}
---
<BaseLayout
  title="书架 | Micah Hale"
  description="按时间轴或标签浏览每月阅读书籍与读后感。"
  currentPath={Astro.url.pathname}
>
  <div class="books-page-shell">
    <section class="page-head page-head-row">
      <div>
        <h2>书架</h2>
        <div class="page-note-spacer"></div>
      </div>
      <div class="mode-switch-wrap">
        <div class="mode-switch">
          <a href="/books/?mode=all" class:list={["switch-link", mode === "all" && "active"]}>全部</a>
          <div class:list={["timeline-combo", mode === "timeline" && "active"]}>
            <a href="/books/?mode=timeline&order=desc" class="timeline-main">时间轴</a>
            <details class="timeline-sort">
              <summary class="timeline-sort-trigger">▾</summary>
              <div class="sort-panel">
                <a href="/books/?mode=timeline&order=desc" class:list={["sort-item", mode === "timeline" && order === "desc" && "active"]}>降序</a>
                <a href="/books/?mode=timeline&order=asc" class:list={["sort-item", mode === "timeline" && order === "asc" && "active"]}>升序</a>
              </div>
            </details>
          </div>
          <a href="/books/?mode=tag&tag=all" class:list={["switch-link", mode === "tag" && "active"]}>标签</a>
        </div>
      </div>
    </section>

    {
      mode === "all" ? (
        <section class="card-grid books-grid">
          {books.length > 0 ? (
            books.map((book) => <BookCard book={book} />)
          ) : (
            <article class="card">
              <p>还没有书籍读后感，请先在 `content/reviews/` 新增 md。</p>
            </article>
          )}
        </section>
      ) : mode === "tag" ? (
        <>
          <section class="tag-filter">
            <a href="/books/?mode=tag&tag=all" class:list={["chip", selectedTag === "all" && "active"]}>全部</a>
            {allTags.map((tag) => (
              <a href={`/books/?mode=tag&tag=${encodeURIComponent(tag)}`} class:list={["chip", selectedTag === tag && "active"]}>
                {tag}
              </a>
            ))}
          </section>

          {tagGroups.length > 0 ? (
            tagGroups.map((group) => (
              <section class="timeline-block">
                <h3 class="timeline-title"># {group.tag}</h3>
                <div class="card-grid books-grid">
                  {group.items.map((book) => <BookCard book={book} />)}
                </div>
              </section>
            ))
          ) : (
            <article class="card">
              <p>还没有书籍读后感，请先在 `content/reviews/` 新增 md。</p>
            </article>
          )}
        </>
      ) : (
        <section class="book-timeline">
          {bookTimeline.length > 0 ? (
            bookTimeline.map((block) => (
              <article class="timeline-node">
                <h3 class="timeline-title">{block.monthLabel}</h3>
                <div class="card-grid books-grid">
                  {block.items.map((book) => <BookCard book={book} />)}
                </div>
              </article>
            ))
          ) : (
            <article class="card">
              <p>还没有书籍读后感，请先在 `content/reviews/` 新增 md。</p>
            </article>
          )}
        </section>
      )
    }
  </div>
</BaseLayout>

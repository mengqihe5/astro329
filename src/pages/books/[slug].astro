---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadBooks } from "../../lib/blog.js";

export const prerender = false;

const { slug } = Astro.params;
const book = loadBooks("desc").find((item) => item.slug === slug);
if (!book) {
  Astro.response.status = 404;
}
---
<BaseLayout title={book ? `${book.title} 读后感` : "书籍未找到"} currentPath={Astro.url.pathname}>
  {
    book ? (
      <>
        <section class="page-head">
          <a class="text-link" href="/books/">返回书架</a>
        </section>
        <article class="card article-full">
          <h2>{book.title}</h2>
          <p class="meta">{book.monthLabel}</p>
          <pre class="md-view">{book.reviewText}</pre>
        </article>
      </>
    ) : (
      <article class="card article-full">
        <h2>书籍未找到</h2>
        <p class="meta">该书籍不存在或已被移除。</p>
      </article>
    )
  }
</BaseLayout>

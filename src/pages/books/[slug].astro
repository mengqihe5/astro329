---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadBooks } from "../../lib/blog.js";

export const prerender = true;

export function getStaticPaths() {
  return loadBooks("desc").map((item) => ({
    params: { slug: item.slug },
    props: { book: item },
  }));
}

const { slug } = Astro.params;
const book = Astro.props.book || loadBooks("desc").find((item) => item.slug === slug);
if (!book) {
  Astro.response.status = 404;
}
const pageTitle = book ? `${book.title} | 读后感` : "书籍未找到";
const pageDescription = book
  ? `${book.monthLabel} 阅读记录：${book.title}`
  : "该书籍不存在或已被移除。";
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={book?.cover || "/app01/book-covers/default-book.svg"}
  ogType={book ? "article" : "website"}
  noindex={!book}
  currentPath={Astro.url.pathname}
>
  {
    book ? (
      <>
        <section class="page-head">
          <a class="text-link" href="/books/">返回书架</a>
        </section>
        <article class="card article-full article-detail" data-pagefind-body>
          <h2>{book.title}</h2>
          <p class="meta">{book.monthLabel}</p>
          <div class="article-content">{book.reviewText}</div>
        </article>
      </>
    ) : (
      <article class="card article-full article-detail">
        <h2>书籍未找到</h2>
        <p class="meta">该书籍不存在或已被移除。</p>
      </article>
    )
  }
</BaseLayout>
